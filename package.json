{
  "name": "fa-starx-bot",
  "version": "20.0.0",
  "description": "FA STARX BOT - Multi-Chain Transfer Bot with WalletConnect & MetaMask RPC Inject",
  "main": "main.js",
  "bin": "control.js",
  "scripts": {
    "start": "node main.js",
    "dev": "node --watch main.js",
    "build": "pkg . --targets node18-linux-x64 --output control"
  },
  "pkg": {
    "assets": [
      "bot/**/*.js",
      "core/**/*.js",
      "auth/**/*.js",
      "utils/**/*.js",
      "rpc/**/*.js",
      "auto/**/*.js",
      "main.js"
    ],
    "outputPath": "."
  },
  "dependencies": {
    "@walletconnect/sign-client": "^2.23.8",
    "dotenv": "^16.0.0",
    "ethers": "^6.16.0",
    "node-os-utils": "^2.0.1",
    "node-telegram-bot-api": "^0.64.0",
    "systeminformation": "^5.31.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "FA STARX",
  "license": "ISC"
}
